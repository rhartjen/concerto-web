VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin route (/admin) — both vars must be set for the route to be usable.
# WARNING: these are inlined into the client bundle at build time.
# Do not commit real values. Use a server-side proxy for production.
VITE_ADMIN_PASSWORD=your-admin-password
VITE_ADMIN_SERVICE_KEY=your-service-role-key
