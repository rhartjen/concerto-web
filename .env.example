# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# Supabase project — find these in the Supabase dashboard under Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin route (/admin) — both vars must be set for the route to be usable.
# WARNING: these are inlined into the client bundle at build time.
# Do not use a real service role key in a public production deployment without
# additional access controls on the /admin path.
VITE_ADMIN_PASSWORD=change-me
VITE_ADMIN_SERVICE_KEY=your-service-role-key
